void vertex() {
// Input:3
	vec3 n_out3p0 = VERTEX;


// Input:6
	vec3 n_out6p0 = NODE_POSITION_WORLD;


// VectorOp:5
	vec2 n_out5p0 = vec2(n_out3p0.xy) + vec2(n_out6p0.xy);


// VectorDecompose:7
	float n_out7p0 = n_out6p0.x;
	float n_out7p1 = n_out6p0.y;
	float n_out7p2 = n_out6p0.z;


// VectorDecompose:4
	float n_out4p0 = n_out3p0.x;
	float n_out4p1 = n_out3p0.y;
	float n_out4p2 = n_out3p0.z;


// FloatOp:8
	float n_out8p0 = n_out7p2 + n_out4p2;


// Input:2
	vec3 n_out2p0 = NORMAL;


// Output:0
	UV = n_out5p0;
	UV2 = vec2(n_out8p0);
	COLOR.rgb = n_out2p0;


}

void fragment() {
// ColorConstant:16
	vec4 n_out16p0 = vec4(0.451000, 0.820000, 0.801550, 1.000000);


// Input:3
	vec2 n_out3p0 = UV;


// Input:7
	vec4 n_out7p0 = COLOR;


// VectorFunc:9
	vec4 n_out9p0 = abs(n_out7p0);


// VectorDecompose:8
	float n_out8p0 = n_out9p0.x;
	float n_out8p1 = n_out9p0.y;
	float n_out8p2 = n_out9p0.z;
	float n_out8p3 = n_out9p0.w;


// Mix:10
	vec3 n_in10p0 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_out10p0 = mix(n_in10p0, vec3(n_out3p0, 0.0), vec3(n_out8p2));


// Input:4
	vec2 n_out4p0 = UV2;


// VectorDecompose:6
	float n_out6p0 = n_out3p0.x;
	float n_out6p1 = n_out3p0.y;


// VectorCompose:12
	vec2 n_out12p0 = vec2(n_out4p0.x, n_out6p0);


// Mix:11
	vec3 n_out11p0 = mix(n_out10p0, vec3(n_out12p0, 0.0), vec3(n_out8p1));


// VectorCompose:14
	vec2 n_out14p0 = vec2(n_out4p0.x, n_out6p1);


// Mix:13
	vec3 n_out13p0 = mix(n_out11p0, vec3(n_out14p0, 0.0), vec3(n_out8p0));


	float n_out15p0;
	float n_out15p1;
// WorleyNoise3D:15
	vec3 n_in15p1 = vec3(0.00000, 0.00000, 0.00000);
	float n_in15p2 = 2.00000;
	float n_in15p3 = 1.00000;
	float n_in15p4 = 0.00000;
	{
		vec2 n_out15p0n_out15p1 = _cellular3dNoiseFunc(vec3((n_out13p0.xy+n_in15p1.xy)*n_in15p2, n_in15p4), min(max(n_in15p3, 0.0), 1.0));
		n_out15p0 = n_out15p0n_out15p1.x;
		n_out15p1 = n_out15p0n_out15p1.y;
	}


// VectorOp:17
	vec3 n_out17p0 = vec3(n_out16p0.xyz) * vec3(n_out15p1);


// FloatConstant:23
	float n_out23p0 = 0.761000;


// FloatOp:20
	float n_in20p1 = 0.62500;
	float n_out20p0 = n_out15p1 * n_in20p1;


// FloatConstant:18
	float n_out18p0 = 1.300000;


// FloatConstant:21
	float n_out21p0 = 1.000000;


// FloatConstant:22
	float n_out22p0 = 0.279000;


// Output:0
	ALBEDO = n_out17p0;
	ALPHA = n_out23p0;
	ROUGHNESS = n_out20p0;
	SPECULAR = n_out18p0;
	CLEARCOAT = n_out21p0;
	CLEARCOAT_ROUGHNESS = n_out22p0;


}
