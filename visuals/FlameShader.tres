	float n_out32p0;
// ScaledTIME:32
	float n_in32p0 = 0.08000;
	{
		n_out32p0 = n_in32p0 * TIME;
	}


	float n_out33p0;
// GradientNoise:33
	float n_in33p1 = 10.00000;
	{
		n_out33p0 = gradient_noise(vec2(n_out32p0), n_in33p1);
	}


// FloatOp:34
	float n_in34p1 = 0.40000;
	float n_out34p0 = n_out33p0 * n_in34p1;


	float n_out5p0;
// ScaledTIME:5
