	float n_out26p0;
// FractalPerlinNoise2D:26
	int n_in26p1 = 4;
	vec3 n_in26p2 = vec3(2.00000, 2.00000, 0.00000);
	float n_in26p3 = 2.00000;
	float n_in26p4 = 0.80000;
	float n_in26p5 = 0.50000;
	float n_in26p6 = 0.60000;
