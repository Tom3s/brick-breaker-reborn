code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform int health = 3;
uniform sampler2D Gradient : filter_linear, repeat_disable;



void fragment() {
// IntParameter:2
	int n_out2p0 = health;


// FloatOp:11
	float n_in11p1 = 1.00000;
	float n_out11p0 = float(n_out2p0) - n_in11p1;


// IntConstant:6
	int n_out6p0 = 3;


// FloatOp:12
	float n_in12p1 = 1.00000;
	float n_out12p0 = float(n_out6p0) - n_in12p1;


// FloatOp:4
	float n_out4p0 = n_out11p0 / n_out12p0;


// Clamp:10
	float n_in10p1 = 0.00000;
	float n_in10p2 = 1.00000;
	float n_out10p0 = clamp(n_out4p0, n_in10p1, n_in10p2);


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Gradient, vec2(n_out10p0));


// FloatConstant:8
	float n_out8p0 = 0.328000;


// FloatConstant:9
	float n_out9p0 = 0.682000;


// Output:0
	ALBEDO = vec3(n_out3p0.xyz);
	ROUGHNESS = n_out8p0;
	SPECULAR = n_out9p0;


}
