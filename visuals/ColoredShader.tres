	vec3 n_out10p0;
// ShiftHSV:10
	float n_in10p1 = -0.05000;
	float n_in10p2 = 0.50000;
	float n_in10p3 = 1.00000;
	{
		n_out10p0 = _hsvChangeHSVChangeFunc(vec3(n_out2p0.xyz), n_in10p1, n_in10p2, n_in10p3);
	}


// Output:0
	ALBEDO = n_out6p0;
	ROUGHNESS = n_out9p0;
	SPECULAR = n_out11p0;
	BACKLIGHT = n_out10p0;


}
